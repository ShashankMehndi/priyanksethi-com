# Public (exposed to the browser)

# GA4 Measurement ID (G-XXXXXXXXXX). The legacy site used a deprecated UA-… tag.
NEXT_PUBLIC_GA_ID=

# reCAPTCHA v3 site key. Provision a fresh key; do not reuse the legacy v2 key.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Server only (never exposed to the browser)

# Where enquiry submissions are emailed. Defaults to enquiry@stunningdentistry.com.
ENQUIRY_EMAIL=

# Sender address shown in the From: header. Use a verified domain.
ENQUIRY_FROM_EMAIL=

# SMTP credentials for nodemailer. If unset, the API logs payloads but does not deliver.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
